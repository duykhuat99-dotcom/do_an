# Biến môi trường cho docker-compose (interpolation).
# Sao chép file này thành `.env` (cùng thư mục docker-compose.yml) rồi điền key.
# File `.env` đã được .gitignore bỏ qua nên KHÔNG bị commit lộ key.

# API key cho CHUỖI FALLBACK LLM (Groq -> OpenRouter -> Gemini -> Ollama local).
# Điền key nào bạn có; tier thiếu key sẽ tự bị bỏ qua. Ollama local luôn là lưới an toàn.
GROQ_API_KEY="your_groq_api_key_here"             # https://console.groq.com/keys
OPENROUTER_API_KEY="your_openrouter_api_key_here" # https://openrouter.ai/keys
GEMINI_API_KEY="your_gemini_api_key_here"         # https://aistudio.google.com/apikey
