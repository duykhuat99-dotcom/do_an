# ============================================================
# CẤU HÌNH HỆ THỐNG — sao chép file này thành `.env` rồi chỉnh
# ============================================================

# ---------- App ----------
APP_NAME="RAG DataMart Chatbot"
APP_ENV=development            # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs

# CORS — domain frontend được phép gọi (phân tách bằng dấu phẩy)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- MySQL DataMart ----------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=datamart
MYSQL_USER=datamart_user
MYSQL_PASSWORD=changeme
# Tài khoản chỉ-đọc dùng để thực thi SQL do LLM sinh (tùy chọn, an toàn hơn)
MYSQL_READONLY_USER=datamart_ro
MYSQL_READONLY_PASSWORD=changeme

# Connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ---------- ChromaDB (Vector Store) ----------
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=datamart_metadata

# ---------- Embedding ----------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RETRIEVAL_TOP_K=5

# ---------- Text-to-SQL ----------
SQL_MAX_RETRIES=1            # số lần LLM tự sửa SQL khi thực thi lỗi (0 = tắt)
HISTORY_CONTEXT_TURNS=3      # số lượt hội thoại gần nhất đưa vào ngữ cảnh (0 = tắt multi-turn)

# ---------- LLM ----------
# Đổi model/nhà cung cấp CHỈ bằng cách sửa các biến dưới đây (không cần sửa code).
LLM_PROVIDER=ollama            # ollama | openai_compat
LLM_MODEL=qwen2.5:1.5b         # nhẹ; xem các lựa chọn ở phần PRESET bên dưới
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=120

# ===== PRESET LLM (bỏ comment 1 khối để dùng) =====
#
# --- A) Ollama LOCAL — model nhẹ (nhớ: ollama pull <model>) ---
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434     # trong Docker: http://ollama:11434
# LLM_MODEL=qwen2.5:1.5b                  # nhẹ, đa năng
# LLM_MODEL=qwen2.5-coder:1.5b            # chuyên SQL/code (hợp Text-to-SQL)
# LLM_MODEL=qwen2.5:3b                    # chất lượng tốt hơn, vẫn nhẹ
# LLM_MODEL=llama3.2:3b
# LLM_MODEL=gemma2:2b
#
# --- B) Dùng API KEY qua chuẩn OpenAI (openai_compat) ---
# LLM_PROVIDER=openai_compat
# LLM_API_KEY=sk-xxxxxxxx                 # dán API key của bạn
#
#   OpenRouter:
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=qwen/qwen-2.5-7b-instruct
#
#   Groq (nhanh, có free tier):
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant
#
#   DeepSeek (rẻ):
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
#
#   Together AI:
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo
#
#   Google Gemini (endpoint tương thích OpenAI):
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.0-flash

# ---------- Metadata ----------
METADATA_DIR=../metadata

# ---------- Auth (1 tài khoản cố định) ----------
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123                 # đổi mật khẩu của bạn
JWT_SECRET=doi-thanh-chuoi-bi-mat-ngau-nhien-dai
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440       # 24 giờ
